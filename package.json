  "version": "1.0.0",
  "description": "Browser-based 8-bit sound effects generator with a dual-oscillator synth engine and WAV export, inspired by 80s arcade machines.",
  "license": "MIT",
  "author": "Tyler Teuber",
  "repository": {
    "type": "git",
    "url": "https://github.com/TTeuber/ArcadeSoundFX.git"
  },
